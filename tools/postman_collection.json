{
  "info": {
    "name": "CRUD API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\"nombre\":\"Juan\",\"email\":\"juan@example.com\",\"password\":\"123456\"}" },
        "url": { "raw": "http://localhost:3000/auth/register", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["auth","register"] }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"email\":\"juan@example.com\",\"password\":\"123456\"}" },
        "url": { "raw": "http://localhost:3000/auth/login", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["auth","login"] }
      }
    },
    {
      "name": "Create Categoria",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"nombre\":\"Salas\",\"descripcion\":\"Muebles para sala\"}" },
        "url": { "raw": "http://localhost:3000/categorias", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["categorias"] }
      }
    },
    {
      "name": "Create Mueble",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"nombre\":\"Sofa\",\"tipo\":\"3 plazas\",\"costo\":\"500\",\"categoriaId\":1}" },
        "url": { "raw": "http://localhost:3000/muebles", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["muebles"] }
      }
    }
  ]
}
